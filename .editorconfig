# EditorConfig — https://editorconfig.org
root = true

# All files
[*]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# YAML, JSON, Markdown files
[*.{yml,yaml,json}]
indent_size = 2

# Markdown files — preserve trailing whitespace for line breaks
[*.md]
trim_trailing_whitespace = false

# Python files
[*.py]
indent_size = 4
max_line_length = 88

# reStructuredText documentation
[*.rst]
indent_size = 3

# TOML files
[*.toml]
indent_size = 4

# INI / CFG files
[*.{ini,cfg}]
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab
